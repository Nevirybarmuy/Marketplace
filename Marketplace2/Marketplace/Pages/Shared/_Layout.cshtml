<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Marketplace</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .navbar {
            background: rgba(255, 255, 255, 0.95) !important;
            box-shadow: 0 2px 20px rgba(0,0,0,0.1);
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.5rem;
            color: #4f46e5 !important;
        }

        .main-container {
            padding: 40px 0;
        }

        .content-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            padding: 40px;
            margin-bottom: 30px;
        }

        .page-title {
            color: #1f2937;
            font-weight: 700;
            margin-bottom: 30px;
            border-bottom: 3px solid #4f46e5;
            padding-bottom: 15px;
        }

        .btn-custom {
            padding: 10px 25px;
            border-radius: 10px;
            font-weight: 600;
            border: none;
        }

        .btn-primary-custom {
            background: #4f46e5;
            color: white;
        }

        .btn-primary-custom:hover {
            background: #4338ca;
            color: white;
        }

        .btn-success-custom {
            background: #10b981;
            color: white;
        }

        .btn-success-custom:hover {
            background: #059669;
            color: white;
        }

        footer {
            background: rgba(255, 255, 255, 0.95);
            padding: 30px 0;
            margin-top: 50px;
            text-align: center;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light">
        <div class="container">
            <a class="navbar-brand" href="/Products">
                <i class="fas fa-shopping-bag me-2"></i>Marketplace
            </a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/Products"><i class="fas fa-list me-1"></i>Товары</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Products/Create"><i class="fas fa-plus me-1"></i>Добавить</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container main-container">
        <div class="content-card">
            @RenderBody()
        </div>
    </div>

    <footer>
        <div class="container">
            <p>&copy; 2026 Marketplace</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>