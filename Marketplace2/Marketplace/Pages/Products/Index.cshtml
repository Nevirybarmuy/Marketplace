@page
@using Marketplace.Pages.Products
@model IndexModel
@{
    ViewData["Title"] = "Каталог товаров";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title mb-0">
        <i class="fas fa-boxes me-2"></i>Каталог товаров
    </h1>
    <a href="/Products/Create" class="btn btn-success-custom btn-custom">
        <i class="fas fa-plus me-2"></i>Добавить товар
    </a>
</div>

@if (!Model.Products.Any())
{
    <div class="text-center py-5">
        <i class="fas fa-box-open" style="font-size: 5rem; color: #d1d5db;"></i>
        <h3 class="mt-3 text-muted">Товары не найдены</h3>
    </div>
}
else
{
    <div class="row">
        @foreach (var product in Model.Products)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@product.Name</h5>
                        <h6 class="card-subtitle mb-2 text-primary">@product.Price.ToString("N2") ₽</h6>
                        <p class="card-text">@product.Description</p>
                        <span class="badge bg-success">@product.Category</span>
                        <p class="mt-2"><small class="text-muted">В наличии: @product.Quantity шт.</small></p>
                        <div class="mt-3">
                            <a href="/Products/Edit/@product.Id" class="btn btn-primary-custom btn-custom btn-sm">
                                <i class="fas fa-edit me-1"></i>Изменить
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}