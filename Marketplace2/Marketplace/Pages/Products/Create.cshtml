@page
@using Marketplace.Pages.Products
@model CreateModel
@{
    ViewData["Title"] = "Добавить товар";
}

<h1 class="page-title">
    <i class="fas fa-plus-circle me-2"></i>Добавить новый товар
</h1>

<form method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="alert alert-danger"></div>

    <div class="mb-3">
        <label asp-for="Product.Name" class="form-label">Название *</label>
        <input asp-for="Product.Name" class="form-control" required />
        <span asp-validation-for="Product.Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Product.Price" class="form-label">Цена *</label>
        <input asp-for="Product.Price" type="number" step="0.01" class="form-control" required />
        <span asp-validation-for="Product.Price" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Product.Quantity" class="form-label">Количество</label>
        <input asp-for="Product.Quantity" type="number" class="form-control" value="0" />
    </div>

    <div class="mb-3">
        <label asp-for="Product.Category" class="form-label">Категория *</label>
        <input asp-for="Product.Category" class="form-control" list="categoryList" required />
        <datalist id="categoryList">
            <option value="Электроника">
            <option value="Одежда">
            <option value="Книги">
            <option value="Дом и сад">
            <option value="Спорт">
        </datalist>
    </div>

    <div class="mb-3">
        <label asp-for="Product.Description" class="form-label">Описание</label>
        <textarea asp-for="Product.Description" class="form-control" rows="3"></textarea>
    </div>

    <div class="mb-3">
        <label asp-for="Product.ImageUrl" class="form-label">URL изображения</label>
        <input asp-for="Product.ImageUrl" class="form-control" />
    </div>

    <div class="mb-3 form-check">
        <input asp-for="Product.IsAvailable" type="checkbox" class="form-check-input" checked />
        <label asp-for="Product.IsAvailable" class="form-check-label">Товар доступен</label>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-success-custom btn-custom">
            <i class="fas fa-save me-2"></i>Сохранить
        </button>
        <a href="/Products" class="btn btn-secondary btn-custom">Отмена</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}