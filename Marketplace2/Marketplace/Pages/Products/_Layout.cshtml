<!DOCTYPE html>
<html lang="ru" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Marketplace</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        /* ===== СВЕТЛАЯ ТЕМА (по умолчанию) ===== */
        :root {
            --bg-primary: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --bg-card: #ffffff;
            --text-primary: #1f2937;
            --text-secondary: #6b7280;
            --navbar-bg: rgba(255, 255, 255, 0.95);
            --footer-bg: rgba(255, 255, 255, 0.95);
            --input-bg: #ffffff;
            --input-border: #d1d5db;
            --shadow-card: 0 20px 60px rgba(0,0,0,0.3);
            --shadow-navbar: 0 2px 20px rgba(0,0,0,0.1);
            --badge-bg: #10b981;
            --card-border: transparent;
        }

        /* ===== ТЁМНАЯ ТЕМА ===== */
        [data-theme="dark"] {
            --bg-primary: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            --bg-card: #1e1e2f;
            --text-primary: #e2e8f0;
            --text-secondary: #94a3b8;
            --navbar-bg: rgba(30, 30, 47, 0.98);
            --footer-bg: rgba(30, 30, 47, 0.98);
            --input-bg: #2d2d44;
            --input-border: #4a4a6a;
            --shadow-card: 0 20px 60px rgba(0,0,0,0.6);
            --shadow-navbar: 0 2px 20px rgba(0,0,0,0.4);
            --badge-bg: #059669;
            --card-border: #3a3a5c;
        }

        body {
            background: var(--bg-primary);
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: var(--text-primary);
            transition: background 0.3s ease, color 0.3s ease;
        }

        .navbar {
            background: var(--navbar-bg) !important;
            box-shadow: var(--shadow-navbar);
            transition: background 0.3s ease, box-shadow 0.3s ease;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.5rem;
            color: #4f46e5 !important;
        }

        .navbar .nav-link {
            color: var(--text-primary) !important;
            font-weight: 500;
        }

        .navbar .nav-link:hover {
            color: #4f46e5 !important;
        }

        .main-container {
            padding: 40px 0;
        }

        .content-card {
            background: var(--bg-card);
            border-radius: 20px;
            box-shadow: var(--shadow-card);
            padding: 40px;
            margin-bottom: 30px;
            border: 1px solid var(--card-border);
            transition: background 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
        }

        .page-title {
            color: var(--text-primary);
            font-weight: 700;
            margin-bottom: 30px;
            border-bottom: 3px solid #4f46e5;
            padding-bottom: 15px;
            transition: color 0.3s ease;
        }

        .form-label {
            color: var(--text-primary);
            font-weight: 500;
        }

        .form-control {
            background: var(--input-bg);
            border-color: var(--input-border);
            color: var(--text-primary);
            transition: background 0.3s ease, border-color 0.3s ease, color 0.3s ease;
        }

        .form-control:focus {
            background: var(--input-bg);
            color: var(--text-primary);
            border-color: #4f46e5;
            box-shadow: 0 0 0 0.2rem rgba(79, 70, 229, 0.25);
        }

        .form-control::placeholder {
            color: var(--text-secondary);
        }

        textarea.form-control {
            background: var(--input-bg);
            color: var(--text-primary);
        }

        .form-check-label {
            color: var(--text-primary);
        }

        .card {
            background: var(--bg-card);
            border: 1px solid var(--card-border);
            color: var(--text-primary);
            transition: background 0.3s ease, border-color 0.3s ease;
        }

        .card-title {
            color: var(--text-primary);
        }

        .card-subtitle {
            color: #4f46e5 !important;
        }

        .card-text {
            color: var(--text-secondary);
        }

        .text-muted {
            color: var(--text-secondary) !important;
        }

        .badge {
            background: var(--badge-bg) !important;
        }

        .btn-custom {
            padding: 10px 25px;
            border-radius: 10px;
            font-weight: 600;
            border: none;
            transition: all 0.3s ease;
        }

        .btn-primary-custom {
            background: #4f46e5;
            color: white;
        }

        .btn-primary-custom:hover {
            background: #4338ca;
            color: white;
            transform: translateY(-2px);
        }

        .btn-success-custom {
            background: #10b981;
            color: white;
        }

        .btn-success-custom:hover {
            background: #059669;
            color: white;
            transform: translateY(-2px);
        }

        .btn-secondary {
            background: #6b7280;
            color: white;
        }

        .btn-secondary:hover {
            background: #4b5563;
            color: white;
        }

        footer {
            background: var(--footer-bg);
            padding: 30px 0;
            margin-top: 50px;
            text-align: center;
            color: var(--text-primary);
            transition: background 0.3s ease, color 0.3s ease;
        }

        /* ===== КНОПКА ПЕРЕКЛЮЧЕНИЯ ТЕМЫ ===== */
        .theme-toggle {
            background: none;
            border: 2px solid var(--input-border);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--text-primary);
            font-size: 1.2rem;
            transition: all 0.3s ease;
            margin-left: 15px;
        }

        .theme-toggle:hover {
            border-color: #4f46e5;
            color: #4f46e5;
            transform: rotate(180deg);
        }

        [data-theme="dark"] .theme-toggle {
            border-color: #4a4a6a;
            color: #e2e8f0;
        }

        [data-theme="dark"] .theme-toggle:hover {
            border-color: #818cf8;
            color: #818cf8;
        }

        /* ===== АНИМАЦИЯ ПЕРЕКЛЮЧЕНИЯ ===== */
        .theme-icon {
            transition: transform 0.3s ease;
        }

        [data-theme="dark"] .theme-icon-sun {
            display: none;
        }

        [data-theme="light"] .theme-icon-moon {
            display: none;
        }

        /* ===== АДАПТИВНОСТЬ ===== */
        @@media (max-width: 768px) {
            .content-card {
                padding: 20px;
            }

            .theme-toggle {
                width: 35px;
                height: 35px;
                font-size: 1rem;
            }
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light">
        <div class="container">
            <a class="navbar-brand" href="/Products">
                <i class="fas fa-shopping-bag me-2"></i>Marketplace
            </a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link" href="/Products"><i class="fas fa-list me-1"></i>Товары</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Products/Create"><i class="fas fa-plus me-1"></i>Добавить</a>
                    </li>
                    <li class="nav-item">
                        <button class="theme-toggle" id="themeToggle" title="Переключить тему">
                            <i class="fas fa-sun theme-icon theme-icon-sun"></i>
                            <i class="fas fa-moon theme-icon theme-icon-moon"></i>
                        </button>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container main-container">
        <div class="content-card">
            @RenderBody()
        </div>
    </div>

    <footer>
        <div class="container">
            <p>&copy; 2026 Marketplace</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- ===== СКРИПТ ПЕРЕКЛЮЧЕНИЯ ТЕМЫ ===== -->
    <script>
        // Проверяем сохранённую тему или системные предпочтения
        function getPreferredTheme() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                return savedTheme;
            }
            return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }

        // Применяем тему
        function setTheme(theme) {
            document.documentElement.setAttribute('data-theme', theme);
            localStorage.setItem('theme', theme);

            // Обновляем иконку кнопки
            const toggle = document.getElementById('themeToggle');
            if (toggle) {
                if (theme === 'dark') {
                    toggle.title = 'Переключить на светлую тему';
                } else {
                    toggle.title = 'Переключить на тёмную тему';
                }
            }
        }

        // Инициализация при загрузке
        document.addEventListener('DOMContentLoaded', function() {
            const currentTheme = getPreferredTheme();
            setTheme(currentTheme);

            // Обработчик клика по кнопке
            const themeToggle = document.getElementById('themeToggle');
            if (themeToggle) {
                themeToggle.addEventListener('click', function() {
                    const currentTheme = document.documentElement.getAttribute('data-theme');
                    const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                    setTheme(newTheme);
                });
            }
        });

        // Слушаем изменения системной темы
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
            if (!localStorage.getItem('theme')) {
                setTheme(e.matches ? 'dark' : 'light');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>